# Copy to .env.test.local and point at a throwaway Postgres instance
# with pgvector installed. NEVER point this at a DB with real data — the
# integration tests create + drop test schemas freely.
#
# Suggestions for local dev:
#   - Docker: `docker run -d --name rogation-test -e POSTGRES_PASSWORD=postgres -p 5433:5432 pgvector/pgvector:pg16`
#     Then: TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/postgres
#   - Supabase: create a free project just for tests, use its connection string
#   - Neon: create a test branch of your main DB

TEST_DATABASE_URL=
