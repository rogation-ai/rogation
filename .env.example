# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Payments
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Background jobs (Inngest)
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# Observability
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

