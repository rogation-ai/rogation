# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Postgres + pgvector via Supabase or Neon)
DATABASE_URL=postgres://user:pass@localhost:5432/rogation

# Auth (Clerk)
# Get these from the Clerk dashboard. Use the test keys (pk_test_... / sk_test_...) locally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook signing secret from Clerk dashboard -> Webhooks -> <your endpoint>.
# Required for /api/webhooks/clerk signature verification.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

