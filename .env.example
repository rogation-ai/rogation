# Public
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Postgres + pgvector via Supabase or Neon)
DATABASE_URL=postgres://user:pass@localhost:5432/rogation

# Auth (Clerk)
# Get these from the Clerk dashboard. Use the test keys (pk_test_... / sk_test_...) locally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook signing secret from Clerk dashboard -> Webhooks -> <your endpoint>.
# Required for /api/webhooks/clerk signature verification.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# LLM providers
# Anthropic for synthesis (Sonnet 4.6) and generation (Haiku 4.5).
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI for evidence embeddings (text-embedding-3-small). One provider per
# concern keeps blast radius small when a key rotates.
OPENAI_API_KEY=sk-...

# Observability
# Sentry DSN for error tracking. Optional — omit and Sentry initializes
# as a no-op so dev works without a project. Same value goes in both
# server + client; the NEXT_PUBLIC prefix exposes it to browser bundles.
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX

# PostHog for product analytics + activation funnel. Browser key goes in
# the NEXT_PUBLIC var; server-side key captures webhook events. Both
# optional; no-op when unset. HOST defaults to https://us.posthog.com.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
# POSTHOG_API_KEY=phx_...

# Langfuse for LLM trace capture (every complete() call records a trace
# with prompt hash + input + output + usage). Requires both keys. Host
# defaults to https://cloud.langfuse.com. Self-host by setting LANGFUSE_HOST.
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Stripe billing. Required — checkout + portal + webhook fail at boot
# without these. Price IDs come from the Stripe dashboard after creating
# the Solo ($49/mo) and Pro ($99/mo) products. Webhook signing secret is
# per-endpoint: one for localhost (stripe listen) + one for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...
STRIPE_PRICE_ID_SOLO=price_...
STRIPE_PRICE_ID_PRO=price_...

# --- Below will be wired in follow-up commits ---

